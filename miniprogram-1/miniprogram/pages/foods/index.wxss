page {
  background: #f5f7fb;
}

.page {
  padding: 16rpx 12rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #444;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.food-form {
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: #f8f9fd;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.food-input {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 24rpx;
}

.food-macros-row {
  display: flex;
  gap: 8rpx;
}

.food-macro-input {
  flex: 1;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 22rpx;
}

.foods-list {
  margin-top: 10rpx;
  max-height: 900rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-row {
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.food-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.food-name {
  font-size: 24rpx;
  color: #333;
}

.food-sub {
  font-size: 22rpx;
  color: #777;
}

.food-tag {
  margin-left: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  border: 1px solid #dde2f0;
  font-size: 20rpx;
  color: #777;
}

.food-tag.user {
  border-color: rgba(47, 128, 237, 0.4);
  color: #2f80ed;
  background: #ecf4ff;
}

.btn {
  height: 70rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #2f80ed;
  color: #ffffff;
}

.btn-danger {
  background: #ffffff;
  color: #eb5757;
  border-radius: 999rpx;
  border: 1px solid rgba(235, 87, 87, 0.35);
  padding: 0 16rpx;
}

