<view class="page">
  <view class="rank-toolbar">
    <picker mode="date" value="{{rankDate}}" bindchange="onRankDateChange">
      <view class="date-pill">日期：{{rankDate}}</view>
    </picker>

    <view class="rank-tabs">
      <view class="rank-tab {{rankTab === 'kcal' ? 'active' : ''}}"
            data-tab="kcal"
            bindtap="onRankTabTap">
        今日 kcal
      </view>
      <view class="rank-tab {{rankTab === 'strength' ? 'active' : ''}}"
            data-tab="strength"
            bindtap="onRankTabTap">
        力量（三大项）
      </view>
    </view>

    <button class="btn btn-outline" bindtap="fetchRank">刷新榜单</button>
  </view>

  <view class="rank-list">
    <view wx:if="{{rankLoading}}" class="rank-status">加载中...</view>
    <view wx:elif="{{!rankRows.length}}" class="rank-status">暂无数据</view>
    <view wx:else>
      <block wx:if="{{rankTab === 'kcal'}}">
        <view wx:for="{{rankRows}}"
              wx:for-item="row"
              wx:key="_id"
              class="rank-row">
          <view class="rank-main">
            <view class="rank-title-row">
              <image wx:if="{{row.avatarUrl}}" class="avatar" mode="aspectFill" src="{{row.avatarUrl}}" />
              <view class="rank-name">#{{index + 1}} {{row.nickname || (row._openid && row._openid.slice(0, 8)) || '匿名'}}</view>
            </view>
            <view class="rank-sub">
              kcal {{row.kcal}} · P {{row.protein_g}} · C {{row.carbs_g}} · F {{row.fat_g}}
            </view>
          </view>
          <view class="rank-extra">{{row.bodyweight_kg}} kg</view>
        </view>
      </block>
      <block wx:elif="{{rankTab === 'strength'}}">
        <view wx:for="{{rankRows}}"
              wx:for-item="row"
              wx:key="_id"
              class="rank-row">
          <view class="rank-main">
            <view class="rank-title-row">
              <image wx:if="{{row.avatarUrl}}" class="avatar" mode="aspectFill" src="{{row.avatarUrl}}" />
              <view class="rank-name">#{{index + 1}} {{row.nickname || (row._openid && row._openid.slice(0, 8)) || '匿名'}}</view>
            </view>
            <view class="rank-sub">
              卧推 {{row.bench_1rm || '-'}} · 硬拉 {{row.deadlift_1rm || '-'}} · 深蹲 {{row.squat_1rm || '-'}}
            </view>
          </view>
          <view class="rank-extra">
            {{row.bodyweight_kg}} kg
          </view>
        </view>
      </block>
    </view>
  </view>
</view>

